{
  "name": "skillwire",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.0",
  "scripts": {
    "predev": "node ./scripts/clean-next.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "next typegen && tsc --noEmit",
    "content:build": "node --import tsx ./lib/refresh.ts --write-local",
    "content:refresh": "node --import tsx ./lib/refresh.ts --write-local --upload-blob",
    "browser:debug": "bash ./scripts/browser-debug.sh"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.0",
    "@ai-sdk/react": "^2.0.0",
    "@vercel/analytics": "^1.5.0",
    "@vercel/blob": "^1.1.1",
    "@vercel/speed-insights": "^1.2.0",
    "ai": "^5.0.0",
    "fast-xml-parser": "^4.5.3",
    "gray-matter": "^4.0.3",
    "gsap": "^3.14.2",
    "lucide-react": "^1.7.0",
    "motion": "^12.7.4",
    "next": "^15.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "smol-toml": "^1.3.1",
    "stripe": "^18.3.0",
    "yaml": "^2.7.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "eslint": "^9.25.1",
    "eslint-config-next": "^15.3.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
