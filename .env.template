# ─────────────────────────────────────────────────────────
# Loop — Environment Variables
# Copy to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Clerk Auth ────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── AI / Gateway ──────────────────────────────────────────
# All AI calls (chat, skill updates, automations) go through the Vercel AI Gateway.
# Get your key from: https://vercel.com/dashboard → AI Gateway → API Keys
AI_GATEWAY_API_KEY=
# Override the default editor model (default: openai/gpt-5-mini)
# LOOP_MODEL=openai/gpt-5-mini

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional — platform fee for skill marketplace checkout (0-100)
# STRIPE_CONNECT_PLATFORM_FEE_PERCENT=10

# ── Resend (email) ───────────────────────────────────────
RESEND_API_KEY=
# Sender address — defaults to "Loop <noreply@localhost>"
# RESEND_FROM_EMAIL=Loop <updates@yourdomain.com>

# ── Admin ─────────────────────────────────────────────────
# Comma-separated admin emails (default: kk23907751@gmail.com)
# ADMIN_EMAILS=admin@example.com
# Session signing secret — falls back to CRON_SECRET
# ADMIN_SESSION_SECRET=

# ── Cron ──────────────────────────────────────────────────
# Shared secret for Vercel cron routes (/api/refresh, /api/cron/weekly-import)
CRON_SECRET=

# ── Site URL ──────────────────────────────────────────────
# Public base URL for SEO, emails, sitemaps (default: http://localhost:3000)
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ── Optional ──────────────────────────────────────────────
# Embed URL for the skill header shader (leave blank to disable)
# NEXT_PUBLIC_SKILL_HEADER_SHADER_EMBED_URL=

# Set to "1" in local dev to sync filesystem .md skills into Supabase on refresh.
# In production this is always off — all skills live in the database.
# LOOP_SYNC_FS=1
